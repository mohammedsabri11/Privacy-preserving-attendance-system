# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/attendance_db

# JWT Authentication
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AES Encryption (32-byte hex key for AES-256)
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Stego images storage path
STEGO_IMAGE_DIR=static/stego_images

# Face recognition
FACE_SIMILARITY_THRESHOLD=0.65

# CORS
FRONTEND_URL=http://localhost:5173
